[MASTER]
ignore=tests
load-plugins=

[MESSAGES CONTROL]
disable=
    C0114,  # missing-module-docstring (we use flake8-docstrings)
    R0903,  # too-few-public-methods

[FORMAT]
max-line-length=100

[DESIGN]
max-args=6
max-locals=15
max-returns=6
max-branches=12
max-statements=50

[SIMILARITIES]
min-similarity-lines=6
ignore-comments=yes
ignore-docstrings=yes

[REPORTS]
output-format=colorized
reports=yes
score=yes
